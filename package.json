{
  "name": "clipcast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "lint": "eslint src/ build.ts eslint.config.js",
    "lint:fix": "eslint src/ build.ts eslint.config.js --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' '*.{json,md,yml}' 'eslint.config.js'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' '*.{json,md,yml}' 'eslint.config.js'",
    "typecheck": "tsc --noEmit",
    "test": "bun test src/",
    "test:acceptance:browser": "playwright test",
    "test:acceptance:http": "bun test tests/acceptance/http/api.test.ts",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/extensions": "^2.14.0",
    "@x402/hono": "^2.14.0",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "playwright": "^1.60.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.60.1"
  }
}
