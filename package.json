{
  "name": "clipcast",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "lint": "eslint src/ build.ts eslint.config.js",
    "lint:fix": "eslint src/ build.ts eslint.config.js --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' '*.{json,md,yml}' 'eslint.config.js'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' '*.{json,md,yml}' 'eslint.config.js'",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun test",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.3",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.6",
    "playwright": "^1.58.2",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.56.1"
  }
}
